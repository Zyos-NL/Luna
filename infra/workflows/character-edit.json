  "12": {
    "class_type": "VAEDecode",
    "inputs": {
      "samples": ["11", 0],
      "vae": ["3", 0]
    },
    "_meta": { "title": "VAE Decode" }
  },
  "16": {
    "class_type": "SaveImage",
    "inputs": {
      "images": ["12", 0],
      "filename_prefix": "characters/test/edit"
    },
    "_meta": { "title": "Save Image -> outputs/characters/<id>/edit_*.png" }
  }
