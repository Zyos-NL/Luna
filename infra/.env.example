# Luna environment — kopieer naar `infra/.env` en vul in. NIET committen (.env staat in .gitignore).

# RunPod API key — voor cloud-LoRA training op RTX 4090 (Fase 4, scripts/train-lora-cloud.mjs).
# Aanmaken: https://www.runpod.io/console/user/settings → API Keys.
RUNPOD_API_KEY=

# Civitai access token — voor model-downloads die login vereisen
# (o.a. Jib Mix Flux v12 SRPO, Photorealistic Skin No Plastic LoRA).
# Aanmaken: https://civitai.com/user/account → API Keys.
CIVITAI_TOKEN=

# HuggingFace token — voor gated repos. Niet strikt nodig voor city96/FLUX.1-dev-gguf,
# wel handig voor toekomstige gated checkpoints/LoRAs.
# Aanmaken: https://huggingface.co/settings/tokens (read-scope is genoeg).
HF_TOKEN=
